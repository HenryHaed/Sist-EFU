# =============================================================================
# EFU Backend — PRODUCCIÓN (plantilla para el administrador del servidor)
# =============================================================================
# Copiar a backend/.env.production (o a backend/.env) en la VM/servidor.
# Ajustar cada valor antes de arrancar la API.
# =============================================================================

NODE_ENV=production
PORT=3000
APP_URL=https://api.efu.umsa.bo

DB_HOST=localhost
DB_PORT=5432
DB_USER=efu_app
DB_PASSWORD=GENERAR_PASSWORD_FUERTE
DB_NAME=efu_db

TYPEORM_SYNCHRONIZE=false

JWT_SECRET=GENERAR_CON_openssl_rand_base64_64
JWT_EXPIRES_IN=8h

CORS_ORIGINS=https://efu.umsa.bo

SWAGGER_ENABLED=false

FRONTEND_URL=https://efu.umsa.bo

SMTP_HOST=smtp.institucion.edu.bo
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EFU <culturas@fcpn.edu.bo>"
