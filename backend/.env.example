# =============================================================================
# EFU Backend — variables de entorno
# =============================================================================
# Copiar a backend/.env (desarrollo) o backend/.env.production (servidor).
# NUNCA subir .env con secretos reales al repositorio.
#
# Convención Node/NestJS (orden de carga):
#   .env.{NODE_ENV}.local → .env.{NODE_ENV} → .env.local → .env
# =============================================================================

# --- Entorno ---
NODE_ENV=development
PORT=3000
# URL pública del backend (logs, referencias). Sin barra final.
APP_URL=http://localhost:3000

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=cambiar_password_seguro
DB_NAME=efu_db

# En producción usar false. En desarrollo true sincroniza el esquema automáticamente.
TYPEORM_SYNCHRONIZE=true

# --- Autenticación JWT ---
# Generar con: openssl rand -base64 64
JWT_SECRET=cambiar_por_secreto_largo_aleatorio
JWT_EXPIRES_IN=8h

# --- CORS (orígenes del frontend, separados por coma) ---
CORS_ORIGINS=http://localhost:5173

# --- Swagger (documentación API en /api) ---
# En producción se recomienda false
SWAGGER_ENABLED=true

# --- Frontend (enlaces en correos: recuperación de contraseña, notificaciones) ---
# URL pública donde los usuarios abren la aplicación. Sin barra final.
FRONTEND_URL=http://localhost:5173

# --- SMTP (correo institucional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EFU <noreply@dominio.edu.bo>"
