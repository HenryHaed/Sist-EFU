# =============================================================================
# EFU Frontend — variables de entorno (Vite)
# =============================================================================
# Prefijo obligatorio: VITE_
#
# Desarrollo: ya incluido en .env.development (localhost).
# Producción: el admin copia .env.production.example → .env.production
#             y ejecuta `npm run build` en el servidor.
# =============================================================================

# Origen del backend (archivos, uploads). Sin barra final.
VITE_API_BASE_URL=http://localhost:3000

# URL base de la API REST (axios). Debe incluir /api/v1
VITE_API_URL=http://localhost:3000/api/v1

# URL pública del frontend (referencia en cliente; el backend usa FRONTEND_URL)
VITE_APP_URL=http://localhost:5173
